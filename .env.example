# ── App ─────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080

# ── Database ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5434
DB_USER=transport
DB_PASSWORD=transport_secret
DB_NAME=transport_db
DB_SSLMODE=disable
DB_MAX_CONNS=20

# ── JWT ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
